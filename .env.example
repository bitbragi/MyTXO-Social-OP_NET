# OPNet Testnet Deployment Configuration
# Copy to .env and fill in your values

# Wallet (generate with: node scripts/generate-wallet.mjs)
MNEMONIC=
WALLET_ADDRESS=

# OPNet Testnet RPC
OPNET_RPC_URL=https://testnet.opnet.org

# Deployed Contract Addresses (populated by deploy scripts)
TOKEN_ADDRESS=
PRESALE_ADDRESS=
FACTORY_ADDRESS=
PROFILE_ADDRESS=
SOCIAL_ADDRESS=
FAUCET_ADDRESS=
REWARDS_ADDRESS=
GOVERNANCE_ADDRESS=
MARKETPLACE_ADDRESS=
COLLECTION_ADDRESS=
