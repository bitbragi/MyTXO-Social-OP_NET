{
  "targets": {
    "token": {
      "outFile": "build/ScribeToken.wasm",
      "use": ["abort=src/token/index/abort"]
    },
    "presale": {
      "outFile": "build/ScribePresale.wasm",
      "use": ["abort=src/presale/index/abort"]
    },
    "factory": {
      "outFile": "build/MyScribeFactory.wasm",
      "use": ["abort=src/factory/index/abort"]
    },
    "profile": {
      "outFile": "build/MyScribeProfile.wasm",
      "use": ["abort=src/profile/index/abort"]
    },
    "social": {
      "outFile": "build/MyScribeSocial.wasm",
      "use": ["abort=src/social/index/abort"]
    },
    "faucet": {
      "outFile": "build/ScribeFaucet.wasm",
      "use": ["abort=src/faucet/index/abort"]
    },
    "rewards": {
      "outFile": "build/ScribeRewards.wasm",
      "use": ["abort=src/rewards/index/abort"]
    },
    "governance": {
      "outFile": "build/ScribeGovernance.wasm",
      "use": ["abort=src/governance/index/abort"]
    },
    "marketplace": {
      "outFile": "build/MyScribeMarketplace.wasm"
    },
    "collection": {
      "outFile": "build/MyScribeCollection.wasm"
    }
  },
  "options": {
    "sourceMap": false,
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": false,
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ],
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 1,
    "exportStart": "start",
    "transform": "@btc-vision/opnet-transform"
  }
}
